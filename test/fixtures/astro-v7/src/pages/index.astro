---
import Helmet, {
	createSeoHead,
	externalScript,
	modulepreload,
	preload,
	stylesheet
} from 'astro-helmet'
import type { HeadItems } from 'astro-helmet'

const seoHead = createSeoHead({
	title: 'Astro Helmet Fixture',
	description: 'Astro 7 fixture page',
	openGraph: {
		url: 'https://example.com/fixture',
		image: 'https://cdn.example.com/fixture.jpg'
	}
})

const resourceHead: HeadItems = {
	link: [
		stylesheet('https://cdn.example.com/site.css'),
		preload('https://cdn.example.com/critical.css', { as: 'style' }),
		preload('https://cdn.example.com/app.js', { as: 'script' }),
		modulepreload('https://cdn.example.com/module.js')
	],
	style: [{ textContent: '.fixture-title { color: rebeccapurple; }' }],
	script: [
		externalScript('https://cdn.example.com/runtime.js'),
		{ textContent: 'window.__helmetFixture = true;' }
	],
	jsonLd: {
		'@type': 'WebSite',
		name: 'Fixture </script>'
	}
}
---

<html lang="en">
	<Helmet
		headItems={[seoHead, resourceHead]}
		options={{ csp: true, validate: false }}
	/>
	<body>
		<h1 class="fixture-title">Astro Helmet Fixture</h1>
	</body>
</html>
